/*
 * mail sending wrapping class
 * properties пҝҪкҪ•пҝҪм ҷ пҝҪлёҳпҝҪмҠӮ
 * mail.smtp.host
 * use case
 * 			String to  = "wefuture@yahoo.co.kr";//,sbang123@shinbiro.com";
 * 			String cc  = "kimdoyle@nate.com,chkim@umlkorea.com";
 * 			String bcc = "wefuture@nate.com";//,sbang123@shinbiro.com";
 * 			String ko = "пҝҪкө№пҝҪмҳғ п§ҚлЁҜл–ҘиӘҳпҝҪ <b>пҝҪлұҜжҸҙпҝҪпҝҪлҝү пҝҪл––пҝҪм”Ә</b> иҮҫлӘ„мҳ„пҝҪпҝҪ пҝҪкҪҢжҝЎпҝҪ пҝҪк¶—п§ҚмҸ…м”Ҳ пҝҪлёҳпҝҪл•І пҝҪлё· пҝҪлҹЎ";
 * 			String en = "пҝҪк¶Ў пҝҪм” з‘ңпҝҪ пҝҪлјұпҝҪлҝ¬пҝҪкөӘ пҝҪлҝ¬еҜғпҝҪ пҝҪк№үжҝЎпҝҪ twentity"; // use 8 bit ko_en
 * 			String text = ko + "\n" + en +"\n"+"е«„пҝҪ пҝҪлёіжҸҙпҝҪ";
 * 			String sub = "п§Һл¶ҝм”Әи№ӮлҢҖк¶Ўж№ІпҝҪ";
 * 			int filesize =1;
 * 			SendMailFacade m = new SendMailFacade("energy","mailenergy",sub,"h5104381@kepco.co.kr",to,cc,bcc,text,filesize);
 * 			m.setHeader(null,null);
 * 			m.setFileDataSource( "C:/ant/lib","ant.jar","ant.jar",0);
 * 			m.send();
 * 
 * 
 * @date 2004. 8. 18.
 * @version
 * @since
 * @author жәҗпҝҪп§ЎмҸҖмғҮ
 * copyright UMLKOREA Co,Ltd
 */


public class SendMailFacade
{
	
	
	Category cat = DisneyLogger.getInstance(SendMailFacade.class.getName());
	
	private MimeMessage msg;
	//private static PropertyReader reader = PropertyReader.getInstance();
	private MimeBodyPart mbp;
	private MimeBodyPart mbps[];
	private MimeMultipart mmp;
	private String id;
	private String passwd;
	private String host;
	private int size;
	private String to;
	private String cc;
	private String bcc;
	private String from;
	private String text;
	private String subject;
	private Transport transport;
	
	
	//private static DailyLog log = DailyLog.getInstance();
	
	private int volumn;
	
	/**
	 *
	 *@param id п§Һл¶ҝм”Ә жҖЁкҫ©м ҷпҝҪм“Ҫ пҝҪлёҳпҝҪм” пҝҪлө’
	 *@param passwd п§Һл¶ҝм”Ә жҖЁкҫ©м ҷпҝҪм“Ҫ пҝҪлҷЈпҝҪл’ӘпҝҪмҚҷпҝҪлұ¶
	 *@param size п§Јв‘ӨпҝҪ пҝҪлҷҶпҝҪм”ӘпҝҪм“Ҫ еӘӣм’–лӢ”
	 *@throws IOException
	 *@throws NoSuchProviderException
	 *@throws MessagingException
	 */
	public SendMailFacade(String host, String port,String id, String passwd, String subject, String from , String to, String cc, String bcc, String text,int size) throws IOException,NoSuchProviderException,MessagingException
	{
		init(host,port,id,passwd,subject,from,to,cc,bcc,text,size);
	}
	
	/**
	 * дәҢмҮұлјұп§һпҝҪ и№ӮпҝҪпҝҪлӢ”жҝЎпҝҪ пҝҪл„ҡпҝҪл–ҠпҝҪлё· п§Һл¶ҝм”ӘпҝҪм“Ј зҸҘлҚҮлҰ°пҝҪмҶ• пҝҪлёіпҝҪл–Һ.
	 * п§Һл¶ҝм”Ә пҝҪкҪҢиё°кҫ©м“Ҫ пҝҪмҶҡеҜғмҺҢлҝү пҝҪлөІпҝҪм”Ә, пҝҪлЈ·з‘ңлҢ„лқҒпҝҪл–ҡз‘ңпҝҪ пҝҪлӢ”пҝҪм ҷпҝҪл№җпҝҪл№һ пҝҪлёіпҝҪл–Һ.
	 * @param id 
	 * @param passwd
	 * @param subject пҝҪм Јп§ҸпҝҪ
	 * @param from пҝҪл„ҡпҝҪл–ҠпҝҪмҳ„
	 * @param to пҝҪлӢ”пҝҪл–ҠпҝҪмҳ„
	 * @param cc п§ЎлӘ„вҖң
	 * @param bcc пҝҪлӢІпҝҪм“¬п§ЎлӘ„вҖң
	 * @param text пҝҪк¶ЎпҝҪмҠң
	 * @param size п§Јв‘ӨпҝҪпҝҪлҷҶпҝҪм”Ә еӘӣпҝҪпҝҪлӢ”
	 * @throws IOException
	 * @throws NoSuchProviderException
	 * @throws MessagingException
	 */
	public void init (String host, String port, final String id, final String passwd, String subject, String from , String to, String cc, String bcc, String text,int size) throws IOException,NoSuchProviderException,MessagingException {
		// пҝҪлҙҪжҝЎм’—лқҒпҝҪл–ҡ зҸҘлҚҮлҰ°пҝҪмҶ•
		Properties props = new Properties();
		
		// stmp з‘ңпҝҪ зҸҘлҚҮлҰ°пҝҪмҶ•
		props.put("mail.smtp.host", host);
		props.put("mail.port", port );
		props.put("mail.smtp.port", port );
		props.put("mail.smtp.auth", "true");
		props.put("mail.smtp.starttls.enable","true");
		


		
		Session session = Session.getDefaultInstance(props, null);
		
		session = Session.getInstance(props,
                new javax.mail.Authenticator() {
                    protected PasswordAuthentication getPasswordAuthentication() {
                        return new PasswordAuthentication(id, passwd);
                    }
                });

        		
		// пҝҪкҪӯпҝҪлҖЎпҝҪм“Ҫ пҝҪлө’иё°кҫ§нүӯ пҝҪмҶ•п§ҺпҝҪ з•°м’•м °
		session.setDebug(true);
		
		//п§Һл¶ҝм”Ә пҝҪмҹҫпҝҪл„ҡ жҖЁкҫ©л§Ғ з—Қв‘Өлұ·
		transport = session.getTransport("smtp");
		
		
		
		// п§Јв‘ӨпҝҪ пҝҪлҷҶпҝҪм”Ә п§Јм„Һв”ҒеӘӣпҝҪ еӘӣпҝҪпҝҪл’«пҝҪлёі mime messageз‘ңпҝҪ пҝҪк№®пҝҪкҪҰ
		// п§Һл¶ҝм”Ә пҝҪл–Ұ пҝҪлёҜпҝҪкө№пҝҪм“Ҫ mime messageеӘӣпҝҪ пҝҪлёҳпҝҪмҠӮ
		createMimeMessage(session);
		
		// п§Һл¶ҝм”Ә пҝҪк¶ЎпҝҪмҠңпҝҪм“Ј пҝҪл–һи№ӮлҢ„лё· пҝҪлӢ” пҝҪм—іпҝҪл’— ж№Ікі•лӮҜ MimeBodyPart пҝҪк№®пҝҪкҪҰ
		setMimeBodyPart();
		
		// п§Јв‘ӨпҝҪ пҝҪлҷҶпҝҪм”ӘпҝҪм“Ҫ еӘӣм’–лӢҪ п§Қлҡ°кІ®пҝҪм“Ҫ MimeBodyPart пҝҪк№®пҝҪкҪҰ
		if( size > 0){
			mbps = new MimeBodyPart[size];
			for( int i = 0 ; i < mbps.length ; i++){
				mbps[i] = createMimeBodyPart();
			}
		}
		
		//MimeBodyPartпҝҪлҝүпҝҪпҝҪпҝҪлёі Container пҝҪк№®пҝҪкҪҰ
		createMimeMultipart();
		this.host = host;
		this.id = id;
		this.passwd = passwd;
		this.size = size;
		this.from = from;
		this.to = to;
		this.cc = cc;
		this.bcc = bcc;
		this.text = text;
		this.subject = subject;
		
		setFrom();
		setSubject();
		//setText(text,0);
		//setText();
		setText(mbp,text); //2010.10.28 и«ӣләӨпҝҪпҝҪмҒә (HTMLпҝҪмӮҺпҝҪл–ҮпҝҪм‘қжҝЎпҝҪ п§Јв‘ӨпҝҪпҝҪлҷҶпҝҪм”Ә пҝҪк¶—пҝҪмҠңпҝҪлёҜж№ІпҝҪ пҝҪмҗһпҝҪлёҝ)
		setRecipients();
		
		if( cc != null){
			setRecipientsCC();
		}
		
		if( bcc != null ){
			setRecipientsBCC();
		}
		setContent();
		//this.setHtmlContent();
		
		setSentDate();
		append();
		
	}
	
	/**
	 * дәҢмҮұлјұп§һпҝҪ mail instanceжҝЎпҝҪ п§Һл¶ҝм”Ә жҖЁкҫ©м ҷпҝҪм“Ј зҸҘлҚҮлҰ°пҝҪмҶ• пҝҪлёҜпҝҪлҝ¬ еӘӣм•№к»ң пҝҪк№®пҝҪкҪҰ
	 * @param m jepetto.mail.Mail instance
	 * @throws IOException
	 * @throws NoSuchProviderException
	 * @throws MessagingException
	 */
	public SendMailFacade(Mail m) throws IOException,NoSuchProviderException,MessagingException
	{
		String host = m.getHost();
		String port = m.getPort();
		String id = m.getId();
		String passwd = m.getPassword();
		String subject = m.getSubject();
		String from = m.getFrom();
		String to = m.getTo();
		String cc = m.getCc();
		String bcc = m.getBcc();
		String text = m.getContext();
		int size = -1;
		try
		{
			size = m.getFiles().length;
		}
		catch(NullPointerException e)
		{
			e.printStackTrace();
			size = -1;
			//log.info("no attach files");
		}
		init(host,port,id,passwd,subject,from,to,cc,bcc,text,size);
	}
	
	/**
	 * п§Һл¶ҝм”Ә пҝҪлёҳпҝҪм” пҝҪлө’з‘ңпҝҪ пҝҪлё·пҝҪл–ҰпҝҪлёіпҝҪл–Һ
	 * @param id
	 */
	public void setId(String id){ this.id = id; }
	
	/**
	 * п§Һл¶ҝм”Ә йҚ®кҫЁпҝҪиё°лҚҠмғҮз‘ңпҝҪ зҸҘлҚҮлҰ°пҝҪмҶ• пҝҪлёіпҝҪл–Һ.
	 * @param passwd
	 */
	public void setPasswd(String passwd){ this.passwd = passwd; }
	
	/**
	 * дәҢмҮұлјұп§һпҝҪ пҝҪкҪӯпҝҪлҖЎпҝҪм“Ј еӘӣпҝҪп§һпҝҪжҖЁпҝҪ MimeMessageз‘ңпҝҪ пҝҪк№®пҝҪкҪҰ
	 * @param session
	 * @return MimeMessage
	 */
	
	private MimeMessage createMimeMessage(Session session){
		msg = new MimeMessage(session);
		return msg;
	}
	
	/**
	 * MimeBodyPart з‘ңпҝҪ пҝҪк№®пҝҪкҪҰ,п§Јв‘ӨпҝҪ пҝҪлҷҶпҝҪм”ӘпҝҪм“Ҫ еӘӣпҝҪпҝҪлӢ” п§Қлҡ°кІ® пҝҪмғҮз•°м’•л§ӮпҝҪл–Һ
	 * @return MimeBodyPart
	 */
	
	private MimeBodyPart createMimeBodyPart(){
		return new MimeBodyPart();
	}
	
	/**
	 * п§Һл¶ҝм”Ә пҝҪк¶ЎпҝҪмҠңпҝҪм“Ј пҝҪл–һи№ӮлҢ„лё· пҝҪлӢ” пҝҪм—іпҝҪл’— ж№Ікі•лӮҜ MimeBodyPart
	 */
	
	private void setMimeBodyPart(){
		mbp = new MimeBodyPart();
	}
	
	/**
	 * MimeBodyPartпҝҪлҝү пҝҪпҝҪпҝҪлёі иҖҢв‘ҰлҖ’пҝҪм” пҝҪкј«
	 * @return MimeMultipart
	 */
	
	public MimeMultipart createMimeMultipart(){
		mmp = new MimeMultipart();
		return mmp;
	}
	
	/**
	 * дәҢмҮұлјұп§һпҝҪ MimeBodyPartпҝҪлҝү п§Һл¶ҝм”Ә пҝҪк¶ЎпҝҪмҠңпҝҪм“Ј пҝҪлё·пҝҪл–ҰпҝҪлёіпҝҪл–Һ
	 * @param mbp
	 * @param text
	 * @throws MessagingException
	 */
	private void setText(MimeBodyPart mbp, String text) throws MessagingException{
		mbp.setContent(text,"text/html; charset=\"utf-8\""); 
	}
	
	/**
	 * дәҢмҮұлјұп§һпҝҪ indexпҝҪлҝү пҝҪл№җпҝҪл–ҰпҝҪлёҜпҝҪл’— MimeBodyPartпҝҪлҝү п§Һл¶ҝм”Ә пҝҪк¶ЎпҝҪмҠңпҝҪм“Ј зҸҘлҚҮлҰ°пҝҪмҶ• пҝҪлёіпҝҪл–Һ.
	 * @param text
	 * @param index
	 * @throws MessagingException
	 */
	private void setText(String text,int index) throws MessagingException{
		mbps[index].setText(text);
	}
	
	/**
	 * ж№Ікі•лӮҜ MimeBodyPart пҝҪлҝү пҝҪк¶ЎпҝҪмҠң пҝҪмҹ»пҝҪмҠң
	 * @param text
	 * @throws MessagingException
	 */
	
	private void setText(String text) throws MessagingException{
		mbp.setText(text);
	}
	
	private void setText() throws MessagingException{
		mbp.setText(text);
	}
	
	/**
	 *п§Һл¶ҝм”Ә пҝҪл„ҡпҝҪл–ҠпҝҪмҳ„з‘ңпҝҪ пҝҪлё·пҝҪл–ҰпҝҪлёіпҝҪл–Һ
	 *@param from
	 *@throws AddressException
	 *@throws MessagingException
	 */
	
	private void setFrom(String from) throws AddressException,MessagingException{
		msg.setFrom(new InternetAddress(from));
	}
	
	private void setFrom() throws AddressException,MessagingException{
		msg.setFrom(new InternetAddress(from));
	}
	
	/**
	 * п§Һл¶ҝм”Ә пҝҪм Јп§Ҹв‘№м“Ј пҝҪлё·пҝҪл–ҰпҝҪлёіпҝҪл–Һ
	 * @param subject
	 * @throws MessagingException
	 */
	private void setSubject(String subject) throws MessagingException{
		msg.setSubject(subject);
	}
	
	private void setSubject() throws MessagingException{
		
		try {
			msg.setSubject(MimeUtility.encodeText(subject, "utf-8", "B"));
		} catch (UnsupportedEncodingException e) {
			// TODO Auto-generated catch block
			e.printStackTrace();
		}
	}

	/**
	 * MimeBodyPartпҝҪлҝү дәҢмҮұлјұп§һпҝҪ пҝҪлҷҶпҝҪм”Әп§ҸлӮҶм‘қжҝЎпҝҪ п§Јв‘ӨпҝҪпҝҪлҷҶпҝҪм”ӘпҝҪм“Ј п§Јв‘ӨпҝҪпҝҪлёіпҝҪл–Һ
	 * @param mbp
	 * @param filename
	 * @throws MessagingException
	 */	
	private void setFileDataSource(MimeBodyPart mbp,String filename) throws MessagingException{
		FileDataSource fds = new FileDataSource(filename);
		mbp.setDataHandler( new DataHandler(fds) );
		// пҝҪлҝӨпҝҪлң‘пҝҪлҝү пҝҪлҷҶпҝҪм”ӘпҝҪм” з”ұкҫ©м“Ј пҝҪкҪӯпҝҪлҳҝпҝҪлё·пҝҪлёЈ base64пҝҪмӮҺпҝҪк№ӯжҝЎпҝҪ и«ӣм„Һлұ¶пҝҪл–Ҷ.
		//mbp2.setFileName(MimeUtility.encodeText(fds.getName(), "utf-8","B"));
		mbp.setFileName(fds.getName());
	}
	
	/**
	 * дәҢмҮұлјұп§һпҝҪ пҝҪлҷҶпҝҪм”ӘпҝҪм“Ј пҝҪл№җпҝҪл–Ұ пҝҪм”ӨпҝҪлҖ“пҝҪл’ӘпҝҪлҝү пҝҪл№җпҝҪл–ҰпҝҪлёҜпҝҪл’— MimeBodyPartпҝҪлҝү п§Јв‘ӨпҝҪпҝҪл–ҶпҝҪк¶Ў
	 * (д»Ҙл¬’мҠӮ) пҝҪлҷҶпҝҪм”Әп§ҸлӮҶпҝҪ base64жҝЎпҝҪ пҝҪм”ӨиӮ„л¶ҫлө«
	 * @param filenam
	 * @param index
	 * @throws MessagingException
	 */
	
	public void setFileDataSource(String filename , String realfilename , int index) throws MessagingException,IOException{
		filename = Util.ko_en(filename);
		FileDataSource fds = new FileDataSource(filename);
		File file = fds.getFile();
		
		mbps[index].setHeader("Content-Type", "multipart/mixed");
		mbps[index].setDataHandler(new DataHandler(fds));
		mbps[index].setFileName(MimeUtility.encodeText(realfilename, "utf-8","B"));
	}
	
	/**
	 * дәҢмҮұлјұп§һпҝҪ еҜғмҺҲмӨҲпҝҪм“Ҫ пҝҪлҷҶпҝҪм”Әп§ҸлӮҶлҝү пҝҪл№җпҝҪл–ҰпҝҪлёҜпҝҪл’— пҝҪлҷҶпҝҪм”ӘпҝҪм“Ј дәҢмҮұлјұп§һпҝҪ indexпҝҪлҝү пҝҪл№җпҝҪл–ҰпҝҪлёҜпҝҪл’— MimeBodypartпҝҪлҝү п§Јв‘ӨпҝҪпҝҪл–ҶпҝҪк¶Ў
	 * @param path
	 * @param filename
	 * @param realfilename
	 * @param index
	 * @throws MessagingException
	 * @throws IOException
	 */
	public void setFileDataSource(String path, String filename , String realfilename , int index) throws MessagingException,IOException{
		filename = Util.ko_en(filename);
		File file = new java.io.File(path,filename);
		FileDataSource fds = new FileDataSource( file );
		
		System.out.println(file.exists());
		mbps[index].setHeader("Content-Type", "multipart/mixed");
		mbps[index].setDataHandler(new DataHandler(fds));

		
		//mbps[index].setFileName(MimeUtility.encodeText(realfilename, "utf-8","Q"));
		mbps[index].setFileName(realfilename);
		
		//mbps[index].attachFile(file);
	}
	
	/**
	 * Message headerз‘ңпҝҪ html ж№Ікі•м»ІпҝҪм‘қжҝЎпҝҪ зҸҘлҚҮлҰ°пҝҪмҶ• пҝҪлёҝ
	 * @throws MessagingException
	 */
	public void setHtmlContent() throws MessagingException{
		//msg.setContent(text,"text/html");
		/*
		try {
			text = MimeUtility.encodeText(text, "utf-8", "B");
		} catch (UnsupportedEncodingException e) {
			// TODO Auto-generated catch block
			e.printStackTrace();
		}
		*/
		msg.setContent(text,"text/html; charset=\"utf-8\""); 
	}
	
	/**
	 * дәҢмҮұлјұп§һпҝҪ Multipartз‘ңпҝҪ MessageпҝҪлҝү пҝҪлё·пҝҪл–ҰпҝҪлёҝ
	 * @param mp
	 * @throws MessagingException
	 */
	private void setContent(Multipart mp) throws MessagingException{
		msg.setContent(mp);
	}
	
	/**
	 * п§Һл¶ҝм”ӘпҝҪм“Ј и№ӮлҢҖк¶Ўж№ІпҝҪ и«ӣл¶ҫмӨҲ пҝҪмҹҫ пҝҪл–’жҖЁкҫЁмӨҲпҝҪкҪҢ MimeMultipart з‘ңпҝҪ MessageпҝҪлҝү п§Јв‘ӨпҝҪ
	 * @throws MessagingException
	 */
	private void setContent() throws MessagingException{
		msg.setContent(mmp);
	}
	
	/**
	 * дәҢмҮұлјұп§һпҝҪ Multipart пҝҪлҝү MimeBodyPartз‘ңпҝҪ п§Јв‘ӨпҝҪпҝҪлёҝ
	 * @param mp Multipart
	 * @param mbp MimeBodyPart
	 * @throws MessagingException
	 */
	private void append(Multipart mp, MimeBodyPart mbp) throws MessagingException{
		mp.addBodyPart(mbp);
	}
	
	/**
	 * ж№Ікі•лӮҜ MimeMultipart пҝҪлҝү пҝҪл№җпҝҪл–Ұ п§Һл¶ҝм”ӘжҖЁпҝҪ ж„ҝпҝҪпҝҪм ҙпҝҪл§Ӯ п§Ҹв‘Өлұә MimeBodyPartз‘ңпҝҪ йҒәмҲҲм—«
	 * @throws MessagingException
	 */
	private void append() throws MessagingException{
		mmp.addBodyPart(mbp);
		for( int i = 0 ; i < size ; i++){
			mmp.addBodyPart(mbps[i]);
		}
	}
	
	/**
	 * п§Һл¶ҝм”Ә и«ӣм’–л„ҡ пҝҪк¶Үп§һпҝҪ
	 * @throws MessagingException
	 */
	private void setSentDate() throws MessagingException{
		msg.setSentDate(new java.util.Date());
	}
	
	/**
	 * п§Һл¶ҝм”Ә пҝҪлҝӨпҝҪлң‘ зҸҘлҚҮлҰ°пҝҪмҶ•, пҝҪм”  еӘӣлҜ©лұҫпҝҪм”  пҝҪкјёпҝҪм”Ә еҜғмҺҢмҠҰ, use-8bitжҝЎпҝҪ пҝҪл§ӮпҝҪл–Һ
	 * @param header
	 * @param bit
	 * @throws MessagingException
	 */
	
	public void setHeader(String header,String bit) throws MessagingException{
		if( header == null || bit == null){
			mbp.setHeader("Content-Transfer-Encoding","8bit");
		}else{
			msg.setHeader(header, bit);
		}//*/
	}
	
	/**
	 * п§Һл¶ҝм”Ә пҝҪмҹҫпҝҪл„ҡ
	 * @throws MessagingException
	 */
	public void send() throws MessagingException{
		try{
			transport.connect(host, id, passwd);
			transport.send(msg, msg.getAllRecipients());
			//transport.send(arg0, arg1)
			transport.close();
		}catch(Exception e){
			e.printStackTrace();
			cat.error(e);
		}
	}
	
	/**
	 * п§Һл¶ҝкҪӯп§һпҝҪпҝҪм“Ҫ sizeз‘ңпҝҪ и«ӣм„‘мҶҡ
	 * @return п§Һл¶ҝкҪӯп§һпҝҪ пҝҪк¶—пҝҪм” п§қпҝҪ
	 * @throws MessagingException
	 */
	public int getSize() throws MessagingException{
		setSize();
		return volumn;
	}
	
	/**
	 * п§Һл¶ҝкҪӯп§һпҝҪпҝҪм“Ҫ sizeз‘ңпҝҪ зҸҘлҚҮлҰ°пҝҪмҶ•
	 * @throws MessagingException
	 */
	public void setSize() throws MessagingException{
		volumn = msg.getSize();
	}
	
	/**
	 * п§Һл¶ҝм”Ә пҝҪлӢ”пҝҪл–ҠпҝҪмҳ„пҝҪлұҫ зҸҘлҚҮлҰ°пҝҪмҶ•
	 * @param str
	 * @throws AddressException
	 * @throws MessagingException
	 */
	
	private void setRecipients() throws AddressException,MessagingException{
		String arr[] = Util.getSplitedStringArr(to , "," );
		InternetAddress[] address = new InternetAddress[arr.length];
		for( int i = 0 ; i < address.length ; i++){
			address[i] = new InternetAddress(arr[i]);
		}
		msg.setRecipients(Message.RecipientType.TO, address);
	}
	
	/**
	 * пҝҪлӢІпҝҪпҝҪ п§ЎлӘ„вҖң п§Һл¶ҝм”Ә пҝҪлӢ”пҝҪл–ҠпҝҪмҳ„пҝҪлұҫ зҸҘлҚҮлҰ°пҝҪмҶ•
	 * @param str
	 * @throws AddressException
	 * @throws MessagingException
	 */
	
	private void setRecipientsBCC() throws AddressException,MessagingException{
		String arr[] = Util.getSplitedStringArr(bcc , "," );
		InternetAddress[] address = new InternetAddress[arr.length];
		for( int i = 0 ; i < address.length ; i++){
			address[i] = new InternetAddress(arr[i]);
		}
		msg.setRecipients(Message.RecipientType.BCC, address);
	}
	
	/**
	 * п§ЎлӘ„вҖң п§Һл¶ҝм”Ә пҝҪлӢ”пҝҪл–ҠпҝҪмҳ„пҝҪлұҫ зҸҘлҚҮлҰ°пҝҪмҶ•
	 * @param str
	 * @throws AddressException
	 * @throws MessagingException
	 */
	
	private void setRecipientsCC() throws AddressException,MessagingException{
		String arr[] = Util.getSplitedStringArr(cc , "," );
		InternetAddress[] address = new InternetAddress[arr.length];
		for( int i = 0 ; i < address.length ; i++){
			address[i] = new InternetAddress(arr[i]);
		}
		msg.setRecipients(Message.RecipientType.CC, address);
	}
	
